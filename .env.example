# Generate different random values for production. Never commit real tokens.
DEVICE_AUTH_TOKEN=replace-with-a-random-device-token
ADMIN_API_TOKEN=replace-with-a-random-admin-token
HEARTBEAT_INTERVAL_SECONDS=5
DEVICE_STALE_AFTER_SECONDS=20
DATABASE_URL=sqlite+aiosqlite:///./data/mambo.db
AUTO_CREATE_SCHEMA=false

# Baidu speech for the OrangePi robot page. Keep real values in the ignored .env.
BAIDU_APP_ID=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_ASR_DEV_PID=1537
BAIDU_TTS_PER=110

# Docker Compose PostgreSQL/Core stack. Use a long URL-safe random value.
POSTGRES_PASSWORD=replace-with-a-random-database-password
CORE_API_PORT=8000

# OrangePi device-agent
DEVICE_ID=orangepi4pro-dev-01
SERVER_WS_URL=ws://127.0.0.1:8000/ws/v1/devices
STATUS_INTERVAL_SECONDS=10
