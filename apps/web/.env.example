# Server-side only. Never add NEXT_PUBLIC_ and never commit real values.
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Required for AI routes on Vercel. Configure one complete pair.
# Preferred pair:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Compatible alternative pair:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional FastAPI Core API adapter. CORE_API_URL must be HTTPS on Vercel.
CORE_API_URL=
CORE_API_ADMIN_TOKEN=
CORE_DEVICE_ID=

# Local/self-hosted in-memory guard only. Leave false unless the proxy is trusted.
TRUST_PROXY_HEADERS=false
