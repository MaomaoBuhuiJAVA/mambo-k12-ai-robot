DEVICE_ID=orangepi4pro-dev-01
DEVICE_AUTH_TOKEN=replace-with-the-server-device-token
SERVER_WS_URL=wss://your-server.example.com/ws/v1/devices
HEARTBEAT_INTERVAL_SECONDS=5
STATUS_INTERVAL_SECONDS=10
LOG_LEVEL=INFO
MEDIA_ROOT=/home/orangepi/.local/share/mambo/media
CAMERA_DEVICE=/dev/video0
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
CAMERA_FPS=30
CAMERA_WARMUP_FRAMES=120
DISPLAY_NAME=:0
XAUTHORITY_PATH=/home/orangepi/.Xauthority
MEDIA_ALLOWED_HOSTS=192.168.1.18
COMMAND_TIMEOUT_SECONDS=30
